{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "pocketarc/ai-workflow",
    "description": "Production-ready AI workflows for Laravel — resilient calls with retries, fallback models, and prompt management.",
    "keywords": ["laravel", "ai", "prism", "retry", "prompts"],
    "license": "MIT",
    "authors": [
        {
            "name": "Bruno Moreira",
            "email": "bruno.moreira@solmyr.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.3",
        "ext-curl": "*",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "mustache/mustache": "^3.0",
        "prism-php/prism": ">=0.99.0, <1.0.0",
        "spatie/yaml-front-matter": "^2.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "captainhook/captainhook": "^5.28",
        "larastan/larastan": "^3",
        "laravel/pint": "^1.24",
        "orchestra/testbench": "^10.0|^11.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.0",
        "spatie/laravel-data": "^4.20"
    },
    "autoload": {
        "psr-4": {
            "AiWorkflow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AiWorkflow\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AiWorkflow\\AiWorkflowServiceProvider"
            ]
        }
    },
    "suggest": {
        "spatie/laravel-data": "Required for sendStructuredData() — automatic schema generation and validation (^4.0)."
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
