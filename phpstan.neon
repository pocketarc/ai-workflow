includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/phpstan/phpstan-strict-rules/rules.neon

parameters:
    paths:
        - src
    level: 10
    ignoreErrors:
        # Eloquent's fluent interface triggers this incorrectly
        - identifier: staticMethod.dynamicCall
    scanFiles:
        - _ide_helper.php
